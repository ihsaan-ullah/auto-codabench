# Copy to .env (which is gitignored) and fill in.

# REQUIRED for alex-mcp (the OpenAlex MCP server on this branch).
# Any working email. Used for the OpenAlex polite-pool — no signup needed.
OPENALEX_MAILTO=you@example.com

# Only needed if you switch BACK to the Semantic Scholar server.
SEMANTIC_SCHOLAR_API_KEY=

# Where generated bundles are written. Defaults to auto_codabench/bundles/.
# AUTOCODABENCH_BUNDLES_ROOT=
