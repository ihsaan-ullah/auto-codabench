# auto-codabench environment variables. gitignored.

# OpenAlex polite pool — required for alex-mcp. Any real email works.
# The free polite pool gives ~10 req/s, plenty for the orchestrator loop.
# If you later get an OpenAlex Premium key, set OPENALEX_API_KEY as well.
OPENALEX_MAILTO=you@email.com

# Optional override for where generated bundles live.
# AUTOCODABENCH_BUNDLES_ROOT=

# Codabench upload credentials (consumed by autocodabench_upload_bundle and
# documentation/codabench_bundle_upload/upload_bundle.py).
# WARNING: anyone who can drive the autocodabench MCP server with these set
# can publish competitions on this account. Do not commit. Do not deploy a
# public web UI with these baked in unless you have a per-user auth layer.
CODABENCH_BASE_URL=https://www.codabench.org
CODABENCH_USERNAME=
CODABENCH_PASSWORD=
